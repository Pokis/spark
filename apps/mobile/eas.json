{
  "cli": {
    "version": ">= 16.20.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-ios": {
      "autoIncrement": true
    }
  },
  "submit": {
    "internal": {
      "android": {
        "track": "internal"
      }
    },
    "alpha": {
      "android": {
        "track": "alpha"
      }
    },
    "beta": {
      "android": {
        "track": "beta"
      }
    },
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
