# Optional: Spark's offline features work when every value is blank.
# Expo embeds EXPO_PUBLIC_* values in the application bundle. They are public
# configuration, never secrets.
EXPO_OWNER=djpokis-team
EXPO_PROJECT_ID=d13c96e7-3533-4fdb-88da-48e0b5a4f932
EXPO_PUBLIC_SPARK_API_URL=
# Cost-bearing remote config requests are opt-in even when an API URL exists.
EXPO_PUBLIC_SPARK_REMOTE_CONFIG_ENABLED=false
# Personal tip links can violate store payment rules. Keep false for Play/App Store builds unless
# the applicable external-offers program and regional requirements are satisfied.
EXPO_PUBLIC_SPARK_CREATOR_TIP_LINK_ENABLED=false
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
