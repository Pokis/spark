# Firebase web configuration is public configuration, not a server credential.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_SPARK_API_URL=http://localhost:8080

# Safe local-only alternative. Copy this file to .env.local and set this to true
# while `npm run emulators` is running.
VITE_USE_FIREBASE_EMULATORS=true
VITE_AUTH_EMULATOR_URL=http://127.0.0.1:9099
VITE_EMULATOR_EMAIL=owner@spark.local
VITE_EMULATOR_PASSWORD=SparkLocalOnly123!
