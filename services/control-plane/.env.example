# Copy this file to services/control-plane/.env. The API loads it automatically.
# These defaults connect only to the local demo project and cannot touch production.
GOOGLE_CLOUD_PROJECT=demo-spark-local
GOOGLE_CLOUD_REGION=europe-central2
GOOGLE_PLAY_PACKAGE_NAME=com.djpokis.sparkhabits.app
ADMIN_EMAIL_ALLOWLIST=owner@spark.local
ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_OIDC_AUDIENCE=
INTERNAL_SERVICE_ACCOUNT=
SUPPORT_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
