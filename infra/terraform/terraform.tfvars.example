project_id              = "djpokis-spark-habits"
region                  = "europe-central2"
firestore_location      = "europe-central2"
# Cost-bearing infrastructure is opt-in. Leave all of these false for local/mobile-only use.
enable_cloud_runtime     = false
enable_google_play_rtdn  = false
enable_maintenance_job   = false
container_image         = ""
admin_email_allowlist   = "djpokis@gmail.com"
allowed_origins         = "http://localhost:5173,https://djpokis-spark-habits.web.app"
google_play_package_name = "com.djpokis.sparkhabits.app"
internal_oidc_audience   = "spark-internal"
support_retention_days   = 90
audit_retention_days     = 365
enable_synthetic_monitoring = false
alert_email                 = ""

# Optional. Alerts do not cap spending.
billing_account_id = ""
monthly_budget_usd = 5
