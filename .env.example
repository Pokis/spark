# Consolidated reference only. Each tool loads environment files from its own
# project directory; see the scoped .env.example files and README.md.
#
# The mobile app works without any of these values.
EXPO_OWNER=
EXPO_PROJECT_ID=
EXPO_PUBLIC_SPARK_API_URL=
EXPO_PUBLIC_SPARK_REMOTE_CONFIG_ENABLED=false
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Admin dashboard (copy to apps/admin/.env.local when cloud setup is complete).
VITE_SPARK_ADMIN_ENABLED=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_SPARK_API_URL=http://localhost:8080
VITE_USE_FIREBASE_EMULATORS=true
VITE_AUTH_EMULATOR_URL=http://127.0.0.1:9099
VITE_EMULATOR_EMAIL=owner@spark.local
VITE_EMULATOR_PASSWORD=SparkLocalOnly123!

# Cloud Run control plane.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=europe-central2
GOOGLE_PLAY_PACKAGE_NAME=com.sparkhabits.app
ADMIN_EMAIL_ALLOWLIST=
ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_OIDC_AUDIENCE=
INTERNAL_SERVICE_ACCOUNT=
SUPPORT_RETENTION_DAYS=90
AUDIT_RETENTION_DAYS=365
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
