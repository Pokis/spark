# The mobile app works without any of these values.
EXPO_PUBLIC_SPARK_API_URL=
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
SPARK_ENABLE_FIREBASE_NATIVE=false

# Admin dashboard (copy to apps/admin/.env.local when cloud setup is complete).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_SPARK_API_URL=

# Cloud Run control plane.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=europe-central2
GOOGLE_PLAY_PACKAGE_NAME=com.sparkhabits.app
ADMIN_EMAIL_ALLOWLIST=
ALLOWED_ORIGINS=http://localhost:5173
